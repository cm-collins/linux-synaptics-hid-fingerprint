# ============================================================
# SYNA30B8 Fingerprint Driver - Dev Container
# Author: Munene
# Laptop: HP EliteBook x360 1040 G7
# Sensor: Synaptics SYNA30B8 (HID over I2C, VID:06CB PID:CE1A)
# ============================================================

FROM rust:latest AS base

# ------------------------------------------------------------
# System labels
# ------------------------------------------------------------
LABEL maintainer="Munene"
LABEL description="SYNA30B8 Fingerprint Driver Dev Environment"
LABEL sensor="Synaptics SYNA30B8 - HID over I2C"
    
# ------------------------------------------------------------
# Environment
# ------------------------------------------------------------
ENV DEBIAN_FRONTEND=noninteractive
ENV CARGO_HOME=/usr/local/cargo
ENV RUSTUP_HOME=/usr/local/rustup
ENV PATH="${CARGO_HOME}/bin:${PATH}"
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

# ------------------------------------------------------------
# Core OS dependencies
# ------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Build essentials
    build-essential \
    cmake \
    ninja-build \
    pkg-config \
    # Clang/LLVM (required for bindgen - Rust FFI to C)
    clang \
    llvm \
    llvm-dev \
    libclang-dev \
    # HID / fingerprint specific
    libhidapi-dev \
    libhidapi-hidraw0 \
    libhidapi-libusb0 \
    libudev-dev \
    libusb-1.0-0-dev \
    # I2C tools
    i2c-tools \
    libi2c-dev \
    # Debugging & tracing
    strace \
    ltrace \
    gdb \
    linux-perf \
    # Python (HID descriptor parsing, scripting)
    python3 \
    python3-pip \
    python3-venv \
    python3-hid \
    # Git and version control
    git \
    git-lfs \
    # Network & download tools
    curl \
    wget \
    unzip \
    jq \
    # Editors / terminal quality of life
    vim \
    nano \
    less \
    htop \
    tree \
    ripgrep \
    fd-find \
    bat \
    # SSL & crypto
    ca-certificates \
    gnupg \
    lsb-release \
    sudo \
    # Needed for udev rules
    udev \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------
# GitHub CLI (gh)
# ------------------------------------------------------------
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] \
    https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------
# Azure CLI (az)
# ------------------------------------------------------------
RUN curl -sL https://aka.ms/InstallAzureCLIDeb | bash \
    && az --version

# ------------------------------------------------------------
# Rust toolchain - latest stable + components
# ------------------------------------------------------------
RUN rustup update stable \
    && rustup default stable \
    && rustup component add \
    clippy \
    rustfmt \
    rust-src \
    rust-analyzer \
    llvm-tools-preview \
    && rustup target add \
    x86_64-unknown-linux-gnu \
    x86_64-unknown-linux-musl

# ------------------------------------------------------------
# Rust cargo tools
# ------------------------------------------------------------
RUN cargo install \
    cargo-watch \
    cargo-edit \
    cargo-expand \
    cargo-audit \
    cargo-outdated \
    cargo-nextest \
    cargo-tarpaulin \
    cross \
    flamegraph \
    cargo-tree \
    && cargo cache --autoclean 2>/dev/null || true

# ------------------------------------------------------------
# Python HID tools (for descriptor parsing & prototyping)
# ------------------------------------------------------------
RUN pip3 install --no-cache-dir --break-system-packages \
    hidapi \
    hid \
    pyusb \
    construct \
    cryptography

# ------------------------------------------------------------
# udev rules for SYNA30B8 sensor access without sudo
# ------------------------------------------------------------
RUN echo 'SUBSYSTEM=="hidraw", ATTRS{idVendor}=="06cb", ATTRS{idProduct}=="ce1a", MODE="0666", GROUP="plugdev", TAG+="uaccess"' \
    > /etc/udev/rules.d/99-syna30b8-fingerprint.rules \
    && echo 'SUBSYSTEM=="hidraw", ATTRS{idVendor}=="06cb", MODE="0666", GROUP="plugdev"' \
    >> /etc/udev/rules.d/99-syna30b8-fingerprint.rules

# ------------------------------------------------------------
# Create non-root dev user
# ------------------------------------------------------------
RUN groupadd -f plugdev \
    && groupadd -f i2c \
    && groupadd --gid 1000 devuser \
    && useradd --uid 1000 --gid 1000 -m devuser \
    && usermod -aG plugdev,dialout,i2c devuser \
    && mkdir -p /etc/sudoers.d \
    && echo "devuser ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/devuser \
    && chmod 0440 /etc/sudoers.d/devuser

# ------------------------------------------------------------
# Workspace
# ------------------------------------------------------------
RUN mkdir -p /workspace && chown devuser:devuser /workspace
WORKDIR /workspace

# Switch to dev user
USER devuser

# Ensure cargo bin is in PATH for devuser
ENV PATH="/home/devuser/.cargo/bin:${CARGO_HOME}/bin:${PATH}"

# ------------------------------------------------------------
# Shell customization - helpful prompt for HID dev
# ------------------------------------------------------------
RUN echo 'export PS1="\[\033[01;35m\]🦀 syna30b8\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ "' \
    >> /home/devuser/.bashrc \
    && echo 'alias ll="ls -alF --color=auto"' >> /home/devuser/.bashrc \
    && echo 'alias watch-sensor="sudo cat /dev/hidraw0 | xxd"' >> /home/devuser/.bashrc \
    && echo 'alias sensor-info="cat /sys/class/hidraw/hidraw0/device/uevent"' >> /home/devuser/.bashrc \
    && echo 'alias cw="cargo watch -x run"' >> /home/devuser/.bashrc \
    && echo 'alias ct="cargo nextest run"' >> /home/devuser/.bashrc \
    && echo 'alias cc="cargo clippy -- -D warnings"' >> /home/devuser/.bashrc

# ------------------------------------------------------------
# Default command
# ------------------------------------------------------------
CMD ["/bin/bash"]
